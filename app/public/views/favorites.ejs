<!DOCTYPE html>
<html lang = "en">
<head>
    <meta charset = "UTF-8">
    <meta name = "viewport" content = "width = device-width, initial-scale = 1.0">
    <title>Favorites</title>
    <link rel = "stylesheet" href="/styles/main.css">
    <link rel = "stylesheet" href="/styles/products.css">
</head>

<body>
    <header>
        <nav class="nav">
            <h1><a href="/">Oikodomos</a></h1>
            <ul>
                <li><a href="#login">Login</a></li>
                <li><a href="#register">Register</a></li>
                <li><a href="/products">Products</a></li>
                <li><a href="/favorites">Favorites</a></li>
            </ul>
        </nav>
    </header>

    <main class = "products-page">
        <section id = "products" class="grid-wrapper">
            <div class = "cards">
                <% if (typeof favorites !== 'undefined' && favorites.length > 0) { %>
                    <% favorites.forEach(favorite => { %>
                        <article class = "product-card">
                            <h3><%= favorite.name %></h3>
                            <p class = "product-description"><%= favorite.price %></p>
                            <a class = "details-button" href ="/products/<%= favorite.productId %>">View Details</a>
                        </article>
                   <% }) %>
                   <% } else { %>
                        <p>No favorites yet</p>
                  <%  } %>
            </div>
        </section>
    </main>

    <footer>
        <p>&copy; 2026 Oikodomos</p>
    </footer>

</body>
</html>
