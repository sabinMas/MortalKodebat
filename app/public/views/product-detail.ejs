<!DOCTYPE html>
<html lang = "en">
<head>
    <meta charset = "UTF-8">
    <meta name = "viewport" content = "width = device-width, initial-scale = 1.0">
    <title>Oikodomos</title>
    <link rel = "stylesheet" href="/styles/main.css">
    <link rel = "stylesheet" href="/styles/product-detail.css">
</head>

<body>
    <header>
        <nav class="nav">
            <h1><a href="/">Oikodomos</a></h1>
            <ul>
                <li><a href="#login">Login</a></li>
                <li><a href="#register">Register</a></li>
                <li><a href="/products">Products</a></li>
            </ul>
        </nav>
    </header>

    <main>
        <section id = "products" class="grid-wrapper">
            <!-- <h2>Products</h2> -->
            <div class = "card">
               <!--product_id, name, price, description, category, url, environment--> 
                <% if (product) { %>
                    <%   %>
                        <article>
                            <h3 class="product-name"><%= product.name %></h3>
                            <p class="product-cat"><%= product.category %></p>
                            <p class="product-env"><%= product.environment %></p>
                            <p class="product-price"><%= product.price %></p>
                            <p class="product-desc"><%= product.description %></p>
                            <a href="<%= product.url %>" class="product-link"">Go to <%= product.name %></a>
                        </article>

                   <%  %>
                   <% } else { %>
                        <p>Extension not available</p>
                  <%  } %>

                    
            </div>
        </section>
    </main>

    <footer>
        <p>&copy; 2026 Oikodomos</p>
    </footer>
    
</body>
</html>