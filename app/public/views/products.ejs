<!DOCTYPE html>
<html lang = "en">
<head>
    <meta charset = "UTF-8">
    <meta name = "viewport" content = "width = device-width, initial-scale = 1.0">
    <title>All Products</title>
    <link rel = "stylesheet" href="/styles/main.css">
</head>

<body>
    <header>
        <nav class="nav">
            <h1><a href="#">Oikodomos</a></h1>
            <ul>
                <li><a href="#login">Login</a></li>
                <li><a href="#register">Register</a></li>
                <li><a href="#products">Products</a></li>
            </ul>
        </nav>
        <section class = "hero grid-wrapper">
            <h2>Build Better With Oikodomos</h2>
            <p>One place, all the extensions you need</p>
        </section>
    </header>

    <main class = "products-page">
        <section id = "products" class="grid-wrapper">
            <!-- <h2>Products</h2> -->
            <div class = "cards">
                <% if (typeof featured !== 'undefined' && featured && featured.length > 3) { %>
                    <% featured.forEach(product => { %>
                        <article>
                            <h3><%= product.name %></h3>
                            <p><%= product.description %></p>
                            <a href ="/products/<%= product.product_id %>">View Details</a>
                            <!--<a href="#">View Details</a>-->
                        </article>
                   <% }) %>
                   <% } else { %>
                        <p>No featured extensions are available</p>
                  <%  } %>
                    
            </div>
        </section>
    </main>

    <footer>
        <p>&copy; 2026 Oikodomos</p>
    </footer>
    
</body>
</html>